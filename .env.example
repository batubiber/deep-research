# Tavily
TAVILY_API_KEY=tvly-dev-...

# Twitter (optional — cookie auth from logged-in X session)
TWITTER_CT0=
TWITTER_AUTH_TOKEN=

# Reddit
REDDIT_USER_AGENT=DeepResearch/0.1.0

# Jina Reader (optional — for higher rate limits)
JINA_API_KEY=jina_...

# vLLM
VLLM_BASE_URL=https://kent-unurbane-many.ngrok-free.dev/v1
VLLM_API_KEY=a
VLLM_MODEL_NAME=qwen3-5

# Thinking budgets (token cinsinden) — tuned for 265k context window
THINKING_BUDGET_PLANNER=1024
THINKING_BUDGET_RESEARCHER=8192
THINKING_BUDGET_ANALYST=4096
THINKING_BUDGET_REVIEWER=1024
THINKING_BUDGET_GAP_RESEARCHER=4096
THINKING_BUDGET_WRITER=16384

# Temperature
TEMPERATURE_PLANNER=0.1
TEMPERATURE_RESEARCHER=0.1
TEMPERATURE_ANALYST=0.2
TEMPERATURE_REVIEWER=0.1
TEMPERATURE_GAP_RESEARCHER=0.1
TEMPERATURE_WRITER=0.4

# Parallelism
MAX_PARALLEL_RESEARCHERS=4

# ArXiv — highest quality sources, enrich as many as possible with full paper HTML
ARXIV_RESULTS_PER_SEARCH=10
ARXIV_ENRICH_COUNT=7

# API
API_HOST=0.0.0.0
API_PORT=8001
API_KEY=
# Comma-separated allowed origins (production: set to your frontend URL)
CORS_ORIGINS=["http://localhost:5173"]
